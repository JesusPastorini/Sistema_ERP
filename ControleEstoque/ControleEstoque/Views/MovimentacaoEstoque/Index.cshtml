@model List<MovimentacaoEstoque>

    @{
    ViewData["Title"] = "Movimentações de Estoque";
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-container--bootstrap-5 {
            width: 100% !important;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        .container-fluid {
            overflow-x: hidden;
        }

        body {
            overflow-x: hidden;
        }
    </style>

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-dropdown {
            z-index: 9999;
        }
    </style>

    <div class="container-fluid">

        <!-- 🔹 HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2 class="fw-bold">
                📦 Movimentações de Estoque
            </h2>

            <a asp-action="Create"
               class="btn btn-success shadow-sm">

                ➕ Nova Entrada

            </a>

        </div>

        <!-- 🔎 FILTRO -->
        <form method="get" class="mb-4">

            <div class="row g-2 align-items-end">

                <div class="col-md-4">

                    <label class="form-label fw-bold">
                        Produto
                    </label>

                    <select id="selectProdutoBusca"
                            name="busca"
                            class="form-select w-100">
                    </select>

                </div>

                <div class="col-md-3">

                    <label class="form-label">
                        Data Inicial
                    </label>

                    <input type="date"
                           name="dataInicio"
                           class="form-control" />

                </div>

                <div class="col-md-3">

                    <label class="form-label">
                        Data Final
                    </label>

                    <input type="date"
                           name="dataFim"
                           class="form-control" />

                </div>

                <div class="col-md-2 d-flex align-items-end">

                    <button class="btn btn-dark btn-sm w-100"
                            style="height: 38px;">

                        🔍

                    </button>

                </div>

            </div>

        </form>

        <div class="row">

            <!-- 🔹 HISTÓRICO -->
            <div class="col-12">

                <div class="card shadow-sm border-0">

                    <div class="card-header bg-primary text-white">
                        Histórico
                    </div>

                    <div class="table-responsive"
                         style="max-height: calc(100vh - 260px); overflow-y: auto;"
                         id="scrollContainerMov">

                        <table class="table table-hover align-middle mb-0"
                               id="tabelaMov">

                            <thead class="table-dark">

                                <tr>
                                    <th>Data</th>
                                    <th>Produto</th>
                                    <th>Tipo</th>
                                    <th>Qtd</th>
                                    <th>Origem</th>
                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var item in Model)
                            {
                                var tipoClass =
                                    item.TipoMovimentacao == "Entrada"
                                    ? "bg-success"
                                    : item.TipoMovimentacao == "Venda"
                                    ? "bg-info"
                                    : "bg-danger";

                                <tr>

                                    <td>
                                        @item.DataMovimentacao.ToString("dd/MM HH:mm")
                                    </td>

                                    <td>

                                        @item.Produto.TipoMadeira

                                        <br />

                                        <small class="text-muted">

                                            @item.Produto.Categoria
                                            (@item.Produto.Dimensoes)

                                        </small>

                                    </td>

                                    <td>

                                        <span class="badge @tipoClass">

                                            @item.TipoMovimentacao

                                        </span>

                                    </td>

                                    <td>
                                        @item.Quantidade
                                    </td>

                                    <td>

                                        @if (item.TipoMovimentacao == "Venda")
                                        {
                                        <span class="text-primary fw-bold">

                                            Venda #@item.VendaId

                                        </span>
                                        }
                                        else
                                        {
                                        @item.Descricao
                                        }

                                    </td>

                                </tr>
                            }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </div>

    @section Scripts {

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        <script>

            // =========================================
            // PRODUTOS
            // =========================================

            $('#selectProdutoBusca').select2({

                theme: 'bootstrap-5',

                placeholder: 'Digite ou clique para buscar...',

                minimumInputLength: 0,

                ajax: {

                    url: '/MovimentacaoEstoque/BuscarProdutosPaginado',

                    dataType: 'json',

                    delay: 150,

                    data: function (params) {

                        return {

                            termo: params.term || '',
                            pagina: params.page || 1
                        };
                    },

                    processResults: function (data) {

                        return {

                            results: data.items.map(item => ({

                                id: item.text,
                                text: item.text

                            })),

                            pagination: {

                                more: data.pagination.more
                            }
                        };
                    }
                }
            });

            // =========================================
            // SCROLL INFINITO
            // =========================================

            let carregando = false;
            let skip = 10;
            let primeiraCarga = true;

            const container =
                document.getElementById('scrollContainerMov');

            container.addEventListener('scroll', async () => {

                if (primeiraCarga) {

                    primeiraCarga = false;
                    return;
                }

                if (carregando) return;

                if (
                    container.scrollTop + container.clientHeight
                    >= container.scrollHeight - 50
                ) {

                    carregando = true;

                    const url =
                        `/MovimentacaoEstoque/CarregarMais?skip=${skip}`;

                    const response = await fetch(url);

                    const dados = await response.json();

                    if (dados.length === 0) {

                        carregando = false;
                        return;
                    }

                    const tabela =
                        document.querySelector('#tabelaMov tbody');

                    dados.forEach(m => {

                        let tipoClass = "bg-danger";

                        if (m.tipo === "Entrada")
                            tipoClass = "bg-success";

                        else if (m.tipo === "Venda")
                            tipoClass = "bg-info";

                        const origem = m.tipo === "Venda"
                            ? `<span class="text-primary fw-bold">Venda #${m.vendaId}</span>`
                            : (m.descricao ?? "");

                        const linha = `
                                        <tr>

                                            <td>${m.data}</td>

                                            <td>

                                                ${m.produto}<br/>

                                                <small class="text-muted">

                                                    ${m.categoria} (${m.dimensoes})

                                                </small>

                                            </td>

                                            <td>

                                                <span class="badge ${tipoClass}">

                                                    ${m.tipo}

                                                </span>

                                            </td>

                                            <td>${m.quantidade}</td>

                                            <td>${origem}</td>

                                        </tr>
                                    `;

                        tabela.insertAdjacentHTML(
                            'beforeend',
                            linha
                        );
                    });

                    skip += 20;

                    carregando = false;
                }
            });

        </script>

    }
