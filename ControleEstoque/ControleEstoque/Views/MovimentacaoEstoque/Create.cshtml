@model MovimentacaoEstoque

@{
    ViewData["Title"] = "Movimentar Estoque";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<style>

    .select2-container {
        width: 100% !important;
    }

    .select2-container--bootstrap-5 .select2-selection {
        min-height: 38px;
    }

    .select2-dropdown {
        z-index: 9999;
    }

    body {
        overflow-x: hidden;
    }
</style>

<div class="container-fluid">

    <div class="d-flex justify-content-between mb-4">

        <h2>
            🔄 Movimentar Estoque
        </h2>

        <a asp-action="Index"
           class="btn btn-outline-secondary">

            Voltar

        </a>

    </div>

    <form asp-action="Create" method="post">

        <div class="row">

            <!-- DADOS -->
            <div class="col-md-5">

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-dark text-white">
                        Dados da Movimentação
                    </div>

                    <div class="card-body">

                        <label class="form-label">
                            Tipo
                        </label>

                        <select asp-for="TipoMovimentacao"
                                class="form-select mb-3"
                                id="tipoMov">

                            <option value="">
                                Selecione
                            </option>

                            <option value="Entrada">
                                Entrada
                            </option>

                            <option value="Saida">
                                Saída
                            </option>

                            <option value="Transferencia">
                                Transferência
                            </option>

                            <option value="Ajuste">
                                Ajuste
                            </option>

                        </select>

                        <!-- PRODUTO ORIGEM -->
                        <label class="form-label">
                            Produto Origem
                        </label>

                        <select asp-for="ProdutoId"
                                id="produtoOrigem"
                                class="form-select mb-3">
                        </select>

                        <!-- ESTOQUE -->
                        <div class="alert alert-info">

                            Estoque Atual:
                            <strong id="estoqueAtual">
                                0
                            </strong>

                        </div>

                        <!-- PRODUTO DESTINO -->
                        <div id="produtoDestinoBox"
                             style="display:none;">

                            <label class="form-label">
                                Produto Destino
                            </label>

                            <select asp-for="ProdutoDestinoId"
                                    id="produtoDestino"
                                    class="form-select mb-3">
                            </select>

                        </div>

                        <label class="form-label"
                               id="labelQuantidade">

                            Quantidade

                        </label>

                        <input asp-for="Quantidade"
                               class="form-control mb-3"
                               id="quantidadeInput" />

                        <label class="form-label">
                            Valor Unitário
                        </label>

                        <input asp-for="ValorUnitario"
                               class="form-control mb-3" />

                        <label class="form-label">
                            Observação
                        </label>

                        <textarea asp-for="Descricao"
                                  class="form-control"
                                  rows="4"></textarea>

                    </div>

                </div>

            </div>

            <!-- RESUMO -->
            <div class="col-md-7">

                <div class="card shadow-sm border-0">

                    <div class="card-header bg-primary text-white">
                        Funcionamento
                    </div>

                    <div class="card-body">

                        <div class="alert alert-light border">

                            <p>
                                <strong>Entrada:</strong>
                                adiciona ao estoque.
                            </p>

                            <p>
                                <strong>Saída:</strong>
                                remove do estoque.
                            </p>

                            <p>
                                <strong>Transferência:</strong>
                                remove da origem e adiciona no destino.
                            </p>

                            <p class="mb-0">
                                <strong>Ajuste:</strong>
                                define o novo estoque final.
                            </p>

                        </div>

                    </div>

                </div>

                <button class="btn btn-success btn-lg mt-4">

                    💾 Salvar Movimentação

                </button>

            </div>

        </div>

    </form>

</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>

        // =========================================
        // SELECT2 PRODUTO ORIGEM
        // =========================================

        $('#produtoOrigem').select2({

            theme: 'bootstrap-5',

            placeholder: 'Digite ou clique para buscar...',

            minimumInputLength: 0,

            ajax: {

                url: '/EntradaEstoque/BuscarProdutosPaginado',

                dataType: 'json',

                delay: 150,

                data: function (params) {

                    return {

                        termo: params.term || '',
                        pagina: params.page || 1
                    };
                },

                processResults: function (data) {

                    return {

                        results: data.items.map(item => ({

                            id: item.id,
                            text: item.text

                        })),

                        pagination: {

                            more: data.pagination.more
                        }
                    };
                }
            }
        });

        // =========================================
        // SELECT2 PRODUTO DESTINO
        // =========================================

        $('#produtoDestino').select2({

            theme: 'bootstrap-5',

            placeholder: 'Digite ou clique para buscar...',

            minimumInputLength: 0,

            ajax: {

                url: '/EntradaEstoque/BuscarProdutosPaginado',

                dataType: 'json',

                delay: 150,

                data: function (params) {

                    return {

                        termo: params.term || '',
                        pagina: params.page || 1
                    };
                },

                processResults: function (data) {

                    return {

                        results: data.items.map(item => ({

                            id: item.id,
                            text: item.text

                        })),

                        pagination: {

                            more: data.pagination.more
                        }
                    };
                }
            }
        });

        // =========================================
        // ELEMENTOS
        // =========================================

        const tipoMov =
            document.getElementById('tipoMov');

        const produtoDestinoBox =
            document.getElementById('produtoDestinoBox');

        const produtoOrigem =
            document.getElementById('produtoOrigem');

        const estoqueAtual =
            document.getElementById('estoqueAtual');

        const quantidadeInput =
            document.getElementById('quantidadeInput');

        const labelQuantidade =
            document.getElementById('labelQuantidade');

        // =========================================
        // CONTROLE TELA
        // =========================================

        function atualizarTela() {

            if (tipoMov.value === "Transferencia") {

                produtoDestinoBox.style.display = "block";
            }
            else {

                produtoDestinoBox.style.display = "none";
            }

            // AJUSTE

            if (tipoMov.value === "Ajuste") {

                labelQuantidade.innerText =
                    "Novo Estoque Final";
            }
            else {

                labelQuantidade.innerText =
                    "Quantidade";
            }
        }

        atualizarTela();

        tipoMov.addEventListener(
            'change',
            atualizarTela
        );

        // =========================================
        // ESTOQUE
        // =========================================

        $('#produtoOrigem').on('change', async function () {

            const produtoId = $(this).val();

            if (!produtoId)
                return;

            const response =
                await fetch(`/MovimentacaoEstoque/ObterEstoque/${produtoId}`);

            const quantidade =
                await response.json();

            estoqueAtual.innerText = quantidade;

            // AJUSTE

            if (tipoMov.value === "Ajuste") {

                quantidadeInput.value = quantidade;
            }
        });

    </script>

}