@model IEnumerable<ControleEstoque.Models.ContasReceber>

    @{
    ViewData["Title"] = "Contas a Receber";
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        body {
            overflow-x: hidden;
        }
    </style>

    <!-- 🔹 HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            💰 Contas a Receber
        </h2>

        <div class="d-flex gap-2">

            <span class="badge bg-secondary align-self-center">

                Total Pendente:
                @Model.Where(c => c.DataPagamento == null).Sum(c => c.Valor).ToString("C")

            </span>

            <a asp-action="Create"
               class="btn btn-primary">

                ➕ Nova Conta

            </a>

        </div>

    </div>

    <!-- 🔎 FILTRO -->
    <form method="get"
          class="mb-4">

        <div class="row g-2 align-items-end">

            <!-- CLIENTE -->
            <div class="col-md-4">

                <label class="form-label">
                    Cliente
                </label>

                <select id="clienteSelect"
                        name="clienteId"
                        class="form-select">
                </select>

            </div>

            <!-- DATA -->
            <div class="col-md-2">

                <label class="form-label">
                    De
                </label>

                <input type="date"
                       name="dataInicio"
                       class="form-control"
                       value="@ViewBag.DataInicio" />

            </div>

            <div class="col-md-2">

                <label class="form-label">
                    Até
                </label>

                <input type="date"
                       name="dataFim"
                       class="form-control"
                       value="@ViewBag.DataFim" />

            </div>

            <!-- STATUS -->
            <div class="col-md-2">

                <label class="form-label">
                    Status
                </label>

                <select name="status"
                        class="form-control">

                    <option value="">
                        Todos
                    </option>

                    <option value="pendente"
                            selected="@(ViewBag.Status == "pendente")">

                        Pendente

                    </option>

                    <option value="pago"
                            selected="@(ViewBag.Status == "pago")">

                        Pago

                    </option>

                    <option value="vencendo"
                            selected="@(ViewBag.Status == "vencendo")">

                        Vencendo

                    </option>

                    <option value="vencido"
                            selected="@(ViewBag.Status == "vencido")">

                        Vencido

                    </option>

                </select>

            </div>

            <div class="col-md-2 d-flex align-items-end">

                <button class="btn btn-dark btn-sm w-100"
                        style="height: 38px;">

                    🔍

                </button>

            </div>

        </div>

    </form>

    <!-- 📋 TABELA -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive"
             style="max-height: 500px; overflow-y: auto;"
             id="scrollContainer">

            <table class="table table-hover align-middle mb-0"
                   id="tabelaContas">

                <thead class="table-dark">

                    <tr>

                        <th>
                            Cliente
                        </th>

                        <th>
                            Vencimento
                        </th>

                        <th>
                            Valor
                        </th>

                        <th>
                            Origem
                        </th>

                        <th>
                            Status
                        </th>

                        <th></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                {
                    var hoje = DateTime.Today;

                    string statusClass;
                    string statusTexto;

                    if (item.DataPagamento.HasValue)
                    {
                        statusClass = "bg-success";
                        statusTexto = $"Pago em {item.DataPagamento.Value:dd/MM}";
                    }
                    else if (item.DataVencimento < hoje)
                    {
                        statusClass = "bg-danger";
                        statusTexto = "Vencido";
                    }
                    else if (item.DataVencimento <= hoje.AddDays(30))
                    {
                        statusClass = "bg-warning text-dark";
                        statusTexto = "Vencendo";
                    }
                    else
                    {
                        statusClass = "bg-secondary";
                        statusTexto = "Pendente";
                    }

                    <tr>

                        <td>
                            @(item.Cliente?.Nome ?? item.Venda?.Cliente?.Nome ?? "N/A")
                        </td>

                        <td>
                            @item.DataVencimento.ToString("dd/MM/yyyy")
                        </td>

                        <td class="fw-bold text-success">
                            @item.Valor.ToString("C")
                        </td>

                        <td>
                            @(item.VendaId != null
                                ? $"Venda #{item.VendaId}"
                                : item.Descricao ?? "Manual")
                        </td>

                        <td>

                            <span class="badge @statusClass">
                                @statusTexto
                            </span>

                        </td>

                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning px-2 py-1">

                                ✏

                            </a>

                            @if (!item.DataPagamento.HasValue)
    {
                            <button class="btn btn-sm btn-success px-2 py-1"
                                    data-bs-toggle="modal"
                                    data-bs-target="#baixarModal"
                                    data-id="@item.Id">

                                ✔

                            </button>
    }

                            <form asp-action="Delete"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Deseja realmente excluir esta conta?');">

                                <button class="btn btn-sm btn-danger px-2 py-1">
                                    🗑
                                </button>

                            </form>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-info text-white px-2 py-1">

                                👁

                            </a>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>

    <!-- MODAL BAIXA -->
    <div class="modal fade"
         id="baixarModal"
         tabindex="-1">

        <div class="modal-dialog">

            <div class="modal-content border-0 shadow">

                <form asp-action="Baixar"
                      method="post">

                    <div class="modal-header bg-success text-white">

                        <h5 class="modal-title">
                            Confirmar Recebimento
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body">

                        <input type="hidden"
                               name="id"
                               id="contaIdInput" />

                        <!-- DATA -->
                        <div class="mb-3">

                            <label class="form-label">
                                Data do Recebimento
                            </label>

                            <input type="date"
                                   name="dataPagamento"
                                   class="form-control"
                                   id="dataPagamentoModal" />

                            <small class="text-muted">
                                Se não informar, será usada a data atual.
                            </small>

                        </div>

                        <!-- OBS -->
                        <div>

                            <label class="form-label">
                                Observação
                            </label>

                            <textarea name="observacao"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Opcional"></textarea>

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">

                            Cancelar

                        </button>

                        <button class="btn btn-success">

                            💰 Confirmar Baixa

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    @section Scripts {

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>



        <script>

            const baixarModal =
                document.getElementById('baixarModal');

            baixarModal.addEventListener('show.bs.modal', function (event) {

                const button = event.relatedTarget;

                const contaId =
                    button.getAttribute('data-id');

                document.getElementById('contaIdInput').value =
                    contaId;

                // DATA HOJE AUTOMÁTICA
                const hoje = new Date();

                const ano = hoje.getFullYear();

                const mes =
                    String(hoje.getMonth() + 1)
                        .padStart(2, '0');

                const dia =
                    String(hoje.getDate())
                        .padStart(2, '0');

                document.getElementById('dataPagamentoModal').value =
                    `${ano}-${mes}-${dia}`;
            });

        // =========================================
        // CLIENTE
        // =========================================

        $('#clienteSelect').select2({

            theme: 'bootstrap-5',

            placeholder: 'Clique ou digite para buscar cliente...',

            minimumInputLength: 0,

            ajax: {

                // 🔥 reutilizando controller já existente
                url: '/Vendas/BuscarClientesPaginado',

                dataType: 'json',

                delay: 150,

                data: function (params) {

                    return {

                        termo: params.term || '',
                        pagina: params.page || 1
                    };
                },

                processResults: function (data) {

                    return {

                        results: data.items.map(item => ({

                            id: item.id,
                            text: item.text

                        })),

                        pagination: {

                            more: data.pagination.more
                        }
                    };
                }
            }
        });

        // =========================================
        // MANTER VALOR SE FILTRADO
        // =========================================

            const clienteAtual = '@ViewBag.ClienteId';
            const clienteTexto = $('<div/>')
                .html('@ViewBag.ClienteTexto')
                .text();

            if (clienteAtual) {

                const option = new Option(
                    clienteTexto,
                    clienteAtual,
                    true,
                    true
                );

                $('#clienteSelect')
                    .append(option)
                    .trigger('change');
            }

        // =========================================
        // SCROLL INFINITO
        // =========================================

        let carregando = false;
        let skip = 10;
        let primeiraCarga = true;

        const container =
            document.getElementById('scrollContainer');

        container.addEventListener('scroll', async () => {

            if (primeiraCarga) {

                primeiraCarga = false;
                return;
            }

            if (carregando)
                return;

            if (
                container.scrollTop + container.clientHeight >=
                container.scrollHeight - 50
            ) {

                carregando = true;

                const clienteId =
                    $('#clienteSelect').val() || '';

                const dataInicio =
                    document.querySelector('[name="dataInicio"]').value;

                const dataFim =
                    document.querySelector('[name="dataFim"]').value;

                const status =
                    document.querySelector('[name="status"]').value;

                const url =
                    `/ContasReceber/CarregarMais?skip=${skip}&clienteId=${encodeURIComponent(clienteId)}&dataInicio=${dataInicio}&dataFim=${dataFim}&status=${status}`;
                const response =
                    await fetch(url);

                const dados =
                    await response.json();

                if (dados.length === 0) {

                    carregando = false;
                    return;
                }

                const tabela =
                    document.querySelector('#tabelaContas tbody');

                dados.forEach(c => {

                    let status = "";

                    if (c.pago)
                        status = `<span class="badge bg-success">Pago</span>`;
                    else if (c.vencido)
                        status = `<span class="badge bg-danger">Vencido</span>`;
                    else if (c.vencendo)
                        status = `<span class="badge bg-warning text-dark">Vencendo</span>`;
                    else
                        status = `<span class="badge bg-secondary">Pendente</span>`;

                    const linha = `

                        <tr>

                            <td>${c.cliente}</td>

                            <td>${c.vencimento}</td>

                            <td class="fw-bold text-success">
                                R$ ${c.valor}
                            </td>

                            <td>${c.origem}</td>

                            <td>${status}</td>

                            <td class="text-end">

                                <a href="/ContasReceber/Edit/${c.id}"
                                   class="btn btn-sm btn-warning px-2 py-1">

                                    ✏

                                </a>

                                ${!c.pago
                                                ? `
                                    <form action="/ContasReceber/Baixar/${c.id}"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Confirmar baixa desta conta?');">

                                        <button class="btn btn-sm btn-success px-2 py-1">
                                            ✔
                                        </button>

                                    </form>
                                    `
                                                : ""
                                            }

                                <form action="/ContasReceber/Delete/${c.id}"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Deseja realmente excluir esta conta?');">

                                    <button class="btn btn-sm btn-danger px-2 py-1">
                                        🗑
                                    </button>

                                </form>

                                <a href="/ContasReceber/Details/${c.id}"
                                   class="btn btn-sm btn-info text-white px-2 py-1">

                                    👁

                                </a>

                            </td>

                        </tr>
                    `;

                    tabela.insertAdjacentHTML(
                        'beforeend',
                        linha
                    );
                });

                skip += 20;

                carregando = false;
            }
        });

        </script>

    }
