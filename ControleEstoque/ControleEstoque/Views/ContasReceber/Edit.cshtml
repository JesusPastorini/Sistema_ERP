@model ControleEstoque.Models.ContasReceber

@{
    ViewData["Title"] = "Editar Conta";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-warning text-dark">

            <h4 class="mb-0">
                ✏ Editar Conta a Receber
            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Edit"
                  method="post">

                <input type="hidden"
                       asp-for="Id" />

                <div class="row g-3">

                    <!-- CLIENTE -->
                    <div class="col-md-6">

                        <label class="form-label">
                            Cliente
                        </label>

                        <select asp-for="ClienteId"
                                asp-items="ViewBag.Clientes"
                                class="form-select">

                            <option value="">
                                Selecione
                            </option>

                        </select>

                    </div>

                    <!-- VALOR -->
                    <div class="col-md-3">

                        <label class="form-label">
                            Valor
                        </label>

                        <input asp-for="Valor"
                               class="form-control" />

                    </div>

                    <!-- VENCIMENTO -->
                    <div class="col-md-3">

                        <label class="form-label">
                            Vencimento
                        </label>

                        <input asp-for="DataVencimento"
                               type="date"
                               class="form-control" />

                    </div>

                    <!-- STATUS -->
                    <div class="col-md-3">

                        <label class="form-label">
                            Status
                        </label>

                        <select id="statusSelect"
                                class="form-select">

                            @if (Model.DataPagamento.HasValue)
                            {
                            <option value="pago" selected>
                                Pago
                            </option>

                            <option value="pendente">
                                Pendente
                            </option>
                            }
                            else
                            {
                            <option value="pendente" selected>
                                Pendente
                            </option>

                            <option value="pago">
                                Pago
                            </option>
                            }

                        </select>

                    </div>

                    <!-- DATA PAGAMENTO -->
                    <div class="col-md-3">

                        <label class="form-label">
                            Data Pagamento
                        </label>

                        <input asp-for="DataPagamento"
                               type="date"
                               class="form-control"
                               id="dataPagamentoInput" />

                    </div>

                    <!-- DESCRIÇÃO -->
                    <div class="col-md-12">

                        <label class="form-label">
                            Descrição
                        </label>

                        <input asp-for="Descricao"
                               class="form-control" />

                    </div>

                    <!-- OBSERVAÇÃO -->
                    <div class="col-md-12">

                        <label class="form-label">
                            Observação
                        </label>

                        <textarea asp-for="Observacao"
                                  class="form-control"
                                  rows="3"></textarea>

                    </div>

                </div>

                <div class="mt-4 d-flex gap-2">

                    <button class="btn btn-success">

                        💾 Salvar

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Voltar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <script>

    const statusSelect =
        document.getElementById('statusSelect');

    const dataPagamentoInput =
        document.getElementById('dataPagamentoInput');

    statusSelect.addEventListener('change', function () {

        if (this.value === 'pago') {

            if (!dataPagamentoInput.value) {

                const hoje = new Date();

                const ano = hoje.getFullYear();

                const mes =
                    String(hoje.getMonth() + 1)
                        .padStart(2, '0');

                const dia =
                    String(hoje.getDate())
                        .padStart(2, '0');

                dataPagamentoInput.value =
                    `${ano}-${mes}-${dia}`;
            }
        }
        else {

            dataPagamentoInput.value = '';
        }
    });

    </script>

}