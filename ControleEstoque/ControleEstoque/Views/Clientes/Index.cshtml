@model List<Cliente>

    @{
    ViewData["Title"] = "Clientes";
    }
    @if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Erro"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

    @if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Sucesso"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        body {
            overflow-x: hidden;
        }
    </style>

    <!-- 🔹 HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            👥 Clientes
        </h2>

        <a asp-action="Create"
           class="btn btn-primary">

            ➕ Novo Cliente

        </a>

    </div>

    <!-- 🔎 FILTRO -->
    <form method="get"
          class="mb-4">

        <div class="row g-2 align-items-end">

            <!-- BUSCA -->
            <div class="col-md-10">

                <label class="form-label">
                    Buscar Cliente
                </label>

                <select id="clienteSelect"
                        name="busca"
                        class="form-select">
                </select>

            </div>

            <div class="col-md-2 d-flex align-items-end">

                <button class="btn btn-dark btn-sm w-100"
                        style="height: 38px;">

                    🔍

                </button>

            </div>

        </div>

    </form>

    <!-- 📋 TABELA -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive"
             style="max-height: 500px; overflow-y: auto;"
             id="scrollContainerClientes">

            <table class="table table-hover align-middle mb-0"
                   id="tabelaClientes">

                <thead class="table-dark">

                    <tr>

                        <th>
                            Cliente
                        </th>

                        <th>
                            CPF/CNPJ
                        </th>

                        <th>
                            Cidade
                        </th>

                        <th>
                            UF
                        </th>

                        <th>
                            Telefone
                        </th>

                        <th>
                            Email
                        </th>

                        <th></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                {
                    <tr>

                        <td>

                            <strong>
                                @item.Nome
                            </strong>

                        </td>

                        <td>

                            <span class="badge bg-secondary">
                                @item.CpfCnpj
                            </span>

                        </td>

                        <td>
                            @item.Cidade
                        </td>

                        <td>

                            <span class="badge bg-dark">
                                @item.Uf
                            </span>

                        </td>

                        <td>
                            @item.Telefone
                        </td>

                        <td>

                            <small class="text-muted">
                                @item.Email
                            </small>

                        </td>

                        <td class="text-end">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-info text-white px-2 py-1">

                                👁

                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning px-2 py-1">

                                ✏

                            </a>

                            <button class="btn btn-sm btn-danger px-2 py-1"
                                    data-bs-toggle="modal"
                                    data-bs-target="#excluirModal"
                                    data-id="@item.Id">

                                🗑

                            </button>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>

    <!-- ================================= -->
    <!-- MODAL EXCLUIR CLIENTE -->
    <!-- ================================= -->

    <div class="modal fade"
         id="excluirModal"
         tabindex="-1">

        <div class="modal-dialog">

            <div class="modal-content border-0 shadow">

                <form asp-action="Delete"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div class="modal-header bg-danger text-white">

                        <h5 class="modal-title">
                            🗑 Excluir Cliente
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body text-center">

                        <input type="hidden"
                               id="clienteIdExcluir"
                               name="id" />

                        <div class="alert alert-warning">

                            Tem certeza que deseja excluir este cliente?

                        </div>

                        <h5 id="clienteNomeExcluir"></h5>

                        <p class="text-muted mb-1">
                            CPF/CNPJ:
                            <span id="clienteCpfExcluir"></span>
                        </p>

                        <p class="text-muted">
                            Telefone:
                            <span id="clienteTelefoneExcluir"></span>
                        </p>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">

                            Cancelar

                        </button>

                        <button type="submit"
                                class="btn btn-danger">

                            🗑 Confirmar Exclusão

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    @section Scripts {

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        <script>

            // =========================================
            // MODAL EXCLUIR CLIENTE
            // =========================================

            const excluirModal =
                document.getElementById('excluirModal');

            excluirModal.addEventListener(
                'show.bs.modal',
                async function (event) {

                    const button =
                        event.relatedTarget;

                    const id =
                        button.getAttribute('data-id');

                    const cliente =
                        await fetch(`/Clientes/ObterCliente/${id}`)
                            .then(r => r.json());

                    document.getElementById('clienteIdExcluir').value =
                        cliente.id;

                    document.getElementById('clienteNomeExcluir').innerText =
                        cliente.nome;

                    document.getElementById('clienteCpfExcluir').innerText =
                        cliente.cpfCnpj ?? '';

                    document.getElementById('clienteTelefoneExcluir').innerText =
                        cliente.telefone ?? '';
                }
            );

        // =========================================
        // CLIENTE
        // =========================================

        $('#clienteSelect').select2({

            theme: 'bootstrap-5',

            placeholder: 'Digite nome ou CPF/CNPJ...',

            minimumInputLength: 0,

            ajax: {

                url: '/Vendas/BuscarClientesPaginado',

                dataType: 'json',

                delay: 150,

                data: function (params) {

                    return {

                        termo: params.term || '',
                        pagina: params.page || 1
                    };
                },

                processResults: function (data) {

                    return {

                        results: data.items,

                        pagination: {

                            more: data.pagination.more
                        }
                    };
                }
            }
        });

        // =========================================
        // MANTER FILTRO SELECIONADO
        // =========================================

        const clienteAtual = '@ViewBag.Busca';

        if (clienteAtual) {

            const option = new Option(
                clienteAtual,
                clienteAtual,
                true,
                true
            );

            $('#clienteSelect')
                .append(option)
                .trigger('change');
        }

        // =========================================
        // SCROLL INFINITO
        // =========================================

        let carregando = false;
        let skip = 10;
        let primeiraCarga = true;

        const container =
            document.getElementById('scrollContainerClientes');

        container.addEventListener('scroll', async () => {

            if (primeiraCarga) {

                primeiraCarga = false;
                return;
            }

            if (carregando)
                return;

            if (
                container.scrollTop + container.clientHeight >=
                container.scrollHeight - 50
            ) {

                carregando = true;

                const busca =
                    $('#clienteSelect').val() || '';

                const url =
                    `/Clientes/CarregarMais?skip=${skip}&busca=${encodeURIComponent(busca)}`;

                const response =
                    await fetch(url);

                const dados =
                    await response.json();

                if (dados.length === 0) {

                    carregando = false;
                    return;
                }

                const tabela =
                    document.querySelector('#tabelaClientes tbody');

                dados.forEach(c => {

                    const linha = `

                        <tr>

                            <td>

                                <strong>
                                    ${c.nome}
                                </strong>

                            </td>

                            <td>

                                <span class="badge bg-secondary">
                                    ${c.cpfCnpj}
                                </span>

                            </td>

                            <td>
                                ${c.cidade ?? ""}
                            </td>

                            <td>

                                <span class="badge bg-dark">
                                    ${c.uf ?? ""}
                                </span>

                            </td>

                            <td>
                                ${c.telefone ?? ""}
                            </td>

                            <td>

                                <small class="text-muted">
                                    ${c.email ?? ""}
                                </small>

                            </td>

                            <td class="text-end">

                                <a href="/Clientes/Details/${c.id}"
                                   class="btn btn-sm btn-info text-white px-2 py-1">

                                    👁

                                </a>

                                <a href="/Clientes/Edit/${c.id}"
                                   class="btn btn-sm btn-warning px-2 py-1">

                                    ✏

                                </a>

                                <a href="/Clientes/Delete/${c.id}"
                                   class="btn btn-sm btn-danger px-2 py-1">

                                    🗑

                                </a>

                            </td>

                        </tr>
                    `;

                    tabela.insertAdjacentHTML(
                        'beforeend',
                        linha
                    );
                });

                skip += 20;

                carregando = false;
            }
        });

        </script>

    }
