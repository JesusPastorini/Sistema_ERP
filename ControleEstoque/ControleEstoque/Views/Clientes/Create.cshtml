@model Cliente

@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="container-fluid">

    <div class="card shadow-lg border-0 mt-4">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">👤 Cadastro de Cliente</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <!-- Nome -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Nome / Razão Social</label>
                        <input asp-for="Nome"
                               class="form-control form-control-lg"
                               placeholder="Nome do cliente" />

                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>

                    <!-- CNPJ -->
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">CNPJ</label>
                        <input asp-for="CpfCnpj"
                               class="form-control form-control-lg"
                               placeholder="00.000.000/0000-00" />

                        <span asp-validation-for="CpfCnpj" class="text-danger"></span>
                    </div>

                    <!-- Telefone -->
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Telefone</label>
                        <input asp-for="Telefone"
                               class="form-control form-control-lg"
                               placeholder="(00) 00000-0000" />
                    </div>

                </div>

                <div class="row">

                    <!-- Email -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input asp-for="Email"
                               class="form-control form-control-lg"
                               placeholder="cliente@email.com" />

                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- CEP -->
                    <div class="col-md-2 mb-3">
                        <label class="form-label fw-bold">CEP</label>
                        <input asp-for="Cep"
                               id="cep"
                               class="form-control form-control-lg"
                               placeholder="00000-000" />
                    </div>

                    <!-- Número -->
                    <div class="col-md-2 mb-3">
                        <label class="form-label fw-bold">Número</label>
                        <input asp-for="Numero"
                               class="form-control form-control-lg"
                               placeholder="123" />
                    </div>

                    <!-- UF -->
                    <div class="col-md-2 mb-3">
                        <label class="form-label fw-bold">UF</label>
                        <input asp-for="Uf"
                               class="form-control form-control-lg"
                               placeholder="PR" />
                    </div>

                </div>

                <div class="row">

                    <!-- Rua -->
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold">Rua</label>
                        <input asp-for="Rua"
                               id="rua"
                               class="form-control form-control-lg"
                               placeholder="Rua do cliente" />
                    </div>

                    <!-- Bairro -->
                    <div class="col-md-3 mb-3">
                        <label class="form-label fw-bold">Bairro</label>
                        <input asp-for="Bairro"
                               id="bairro"
                               class="form-control form-control-lg"
                               placeholder="Bairro" />
                    </div>

                    <!-- Cidade -->
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Cidade</label>
                        <input asp-for="Cidade"
                               id="cidade"
                               class="form-control form-control-lg"
                               placeholder="Cidade" />
                    </div>

                </div>

                <div class="row">

                    <!-- Complemento -->
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Complemento</label>
                        <input asp-for="Complemento"
                               class="form-control form-control-lg"
                               placeholder="Sala, bloco, referência..." />
                    </div>

                </div>

                <hr />

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-primary btn-lg">
                        💾 Salvar Cliente
                    </button>
                </div>

            </form>

        </div>

    </div>

</div>