@model Cliente

@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="mb-1">👤 Detalhes do Cliente</h2>

            <small class="text-muted">
                Informações completas do cadastro
            </small>
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-warning">
                ✏ Editar
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                ← Voltar
            </a>

        </div>

    </div>

    <!-- CARD -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                📄 Dados do Cliente
            </h5>
        </div>

        <div class="card-body">

            <!-- DADOS PRINCIPAIS -->
            <div class="row">

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Nome / Razão Social
                    </label>

                    <div class="fs-5 fw-semibold">
                        @Model.Nome
                    </div>
                </div>

                <div class="col-md-3 mb-4">
                    <label class="form-label fw-bold text-muted">
                        CNPJ
                    </label>

                    <div>
                        <span class="badge bg-secondary fs-6">
                            @Model.CpfCnpj
                        </span>
                    </div>
                </div>

                <div class="col-md-3 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Telefone
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Telefone)
                            ? "Não informado"
                            : Model.Telefone)
                    </div>
                </div>

            </div>

            <!-- EMAIL -->
            <div class="row">

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Email
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Email)
                            ? "Não informado"
                            : Model.Email)
                    </div>
                </div>

                <div class="col-md-3 mb-4">
                    <label class="form-label fw-bold text-muted">
                        CEP
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Cep)
                            ? "Não informado"
                            : Model.Cep)
                    </div>
                </div>

                <div class="col-md-3 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Número
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Numero)
                            ? "Não informado"
                            : Model.Numero)
                    </div>
                </div>

            </div>

            <hr />

            <!-- ENDEREÇO -->
            <h5 class="mb-4">
                📍 Endereço
            </h5>

            <div class="row">

                <div class="col-md-5 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Rua / Logradouro
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Rua)
                            ? "Não informado"
                            : Model.Rua)
                    </div>
                </div>

                <div class="col-md-3 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Bairro
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Bairro)
                            ? "Não informado"
                            : Model.Bairro)
                    </div>
                </div>

                <div class="col-md-2 mb-4">
                    <label class="form-label fw-bold text-muted">
                        Cidade
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Cidade)
                            ? "Não informado"
                            : Model.Cidade)
                    </div>
                </div>

                <div class="col-md-2 mb-4">
                    <label class="form-label fw-bold text-muted">
                        UF
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Uf)
                            ? "Não informado"
                            : Model.Uf)
                    </div>
                </div>

            </div>

            <!-- COMPLEMENTO -->
            <div class="row">

                <div class="col-md-12 mb-2">
                    <label class="form-label fw-bold text-muted">
                        Complemento
                    </label>

                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Complemento)
                            ? "Não informado"
                            : Model.Complemento)
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>