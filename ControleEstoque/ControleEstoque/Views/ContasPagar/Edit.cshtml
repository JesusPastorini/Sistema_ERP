@model ControleEstoque.Models.ContasPagar

@{
    ViewData["Title"] = "Editar Conta a Pagar";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<style>

    .select2-container {
        width: 100% !important;
    }

    .select2-container--bootstrap-5 .select2-selection {
        min-height: 38px;
    }

    .select2-dropdown {
        z-index: 9999;
    }

    body {
        overflow-x: hidden;
    }

    .form-control:focus,
    .form-select:focus,
    .select2-container--bootstrap-5 .select2-selection:focus,
    .select2-container--bootstrap-5.select2-container--focus .select2-selection {
        border-color: #ced4da !important;
        box-shadow: none !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>
        ✏ Editar Conta a Pagar
    </h2>

    <a asp-action="Index"
       class="btn btn-outline-secondary">

        ← Voltar

    </a>

</div>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly"
         class="text-danger mb-3">
    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-warning">

            <h5 class="mb-0 text-dark">
                💸 Alterar Conta
            </h5>

        </div>

        <div class="card-body">

            <div class="row g-3">

                <!-- FORNECEDOR -->
                <div class="col-md-6">

                    <label class="form-label fw-bold">
                        Fornecedor
                    </label>

                    <select asp-for="FornecedorId"
                            id="FornecedorId"
                            class="form-select">

                        @if (Model.FornecedorId != null &&
                       Model.Fornecedor != null)
                        {
                        <option value="@Model.FornecedorId" selected>
                            @Model.Fornecedor.NomeFantasia
                        </option>
                        }

                    </select>

                </div>

                <!-- VALOR -->
                <div class="col-md-3">

                    <label class="form-label fw-bold">
                        Valor
                    </label>

                    <input asp-for="Valor"
                           type="number"
                           step="0.01"
                           class="form-control border-danger" />

                </div>

                <!-- VENCIMENTO -->
                <div class="col-md-3">

                    <label class="form-label fw-bold">
                        Vencimento
                    </label>

                    <input asp-for="DataVencimento"
                           type="date"
                           class="form-control" />

                </div>

                <!-- DESCRIÇÃO -->
                <div class="col-md-6">

                    <label class="form-label fw-bold">
                        Descrição
                    </label>

                    <input asp-for="Descricao"
                           class="form-control"
                           placeholder="Ex: Compra de madeira, frete..." />

                </div>

                <!-- CATEGORIA -->
                <div class="col-md-3">

                    <label class="form-label fw-bold">
                        Categoria
                    </label>

                    <select asp-for="Categoria"
                            class="form-select">

                        <option value="Madeira">
                            🌲 Compra de Madeira
                        </option>

                        <option value="Frete">
                            🚚 Frete/Transporte
                        </option>

                        <option value="Energia">
                            ⚡ Energia Elétrica
                        </option>

                        <option value="Manutenção">
                            ⚙️ Manutenção
                        </option>

                        <option value="Outros">
                            💰 Outros Gastos
                        </option>

                    </select>

                </div>

                <!-- DATA PAGAMENTO -->
                <div class="col-md-3">

                    <label class="form-label fw-bold">
                        Data Pagamento
                    </label>

                    <input asp-for="DataPagamento"
                           type="date"
                           class="form-control" />

                </div>

                <!-- URL -->
                <div class="col-md-12">

                    <label class="form-label fw-bold">
                        🔗 Documento / Nota
                    </label>

                    <input asp-for="UrlDocumento"
                           class="form-control"
                           placeholder="Link Google Drive..." />

                </div>

                <!-- BOTÕES -->
                <div class="col-md-12">

                    <div class="d-flex justify-content-end gap-2 mt-2">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancelar

                        </a>

                        <button type="submit"
                                class="btn btn-warning px-4">

                            💾 Salvar Alterações

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</form>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>

    // =====================================
    // SELECT2 FORNECEDOR
    // =====================================

    $('#FornecedorId').select2({

        theme: 'bootstrap-5',

        placeholder: 'Digite ou clique para buscar fornecedor...',

        minimumInputLength: 0,

        ajax: {

            url: '/EntradaEstoque/BuscarFornecedoresPaginado',

            dataType: 'json',

            delay: 150,

            data: function (params) {

                return {

                    termo: params.term || '',
                    pagina: params.page || 1
                };
            },

            processResults: function (data) {

                return {

                    results: data.items.map(item => ({

                        id: item.id,
                        text: item.text

                    })),

                    pagination: {

                        more: data.pagination.more
                    }
                };
            }
        }
    });

</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}