@model IEnumerable<ControleEstoque.Models.ContasPagar>

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        body {
            overflow-x: hidden;
        }
    </style>

    <!-- 🔹 HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>💸 Contas a Pagar</h2>

        <div class="d-flex gap-2">

            <span class="badge bg-secondary align-self-center">

                Total Pendente:
                @Model.Where(c => c.DataPagamento == null).Sum(c => c.Valor).ToString("C")

            </span>

            <a asp-action="Create"
               class="btn btn-danger">

                ➕ Nova Conta

            </a>

        </div>

    </div>

    <!-- 🔎 FILTRO -->
    <form method="get"
          class="mb-4">

        <div class="row g-2 align-items-end">

            <!-- FORNECEDOR -->
            <div class="col-md-3">

                <label class="form-label">
                    Fornecedor
                </label>

                <select id="fornecedorSelect"
                        name="fornecedorId"
                        class="form-select">
                </select>

            </div>

            <div class="col-md-2">

                <label class="form-label">
                    Data Inicial
                </label>

                <input type="date"
                       name="dataInicio"
                       class="form-control"
                       value="@ViewBag.DataInicio" />

            </div>

            <div class="col-md-2">

                <label class="form-label">
                    Data Final
                </label>

                <input type="date"
                       name="dataFim"
                       class="form-control"
                       value="@ViewBag.DataFim" />

            </div>

            <div class="col-md-3">

                <label class="form-label">
                    Status
                </label>

                <select name="status"
                        class="form-control">

                    <option value="">
                        Todos
                    </option>

                    <option value="pendente"
                            selected="@(ViewBag.Status == "pendente")">

                        Pendente

                    </option>

                    <option value="pago"
                            selected="@(ViewBag.Status == "pago")">

                        Pago

                    </option>

                    <option value="vencendo"
                            selected="@(ViewBag.Status == "vencendo")">

                        Vencendo

                    </option>

                    <option value="vencido"
                            selected="@(ViewBag.Status == "vencido")">

                        Vencido

                    </option>

                </select>

            </div>

            <div class="col-md-2 d-flex align-items-end">

                <button class="btn btn-dark btn-sm w-100"
                        style="height: 38px;">

                    🔍

                </button>

            </div>

        </div>

    </form>

    <!-- 📋 TABELA -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive"
             style="max-height: 500px; overflow-y: auto;"
             id="scrollPagar">

            <table class="table table-hover align-middle mb-0"
                   id="tabelaPagar">

                <thead class="table-dark">

                    <tr>

                        <th>
                            Fornecedor
                        </th>

                        <th>
                            Vencimento
                        </th>

                        <th>
                            Descrição
                        </th>

                        <th>
                            Categoria
                        </th>

                        <th>
                            Valor
                        </th>

                        <th>
                            Documento
                        </th>

                        <th>
                            Status
                        </th>

                        <th></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                {
                    var hoje = DateTime.Today;

                    string statusClass;
                    string statusTexto;

                    if (item.DataPagamento.HasValue)
                    {
                        statusClass = "bg-success";
                        statusTexto = $"Pago em {item.DataPagamento.Value:dd/MM}";
                    }
                    else if (item.DataVencimento < hoje)
                    {
                        statusClass = "bg-danger";
                        statusTexto = "Vencido";
                    }
                    else if (item.DataVencimento <= hoje.AddDays(30))
                    {
                        statusClass = "bg-warning text-dark";
                        statusTexto = "Vencendo";
                    }
                    else
                    {
                        statusClass = "bg-secondary";
                        statusTexto = "Pendente";
                    }

                    <tr>

                        <td>
                            @(item.Fornecedor?.NomeFantasia ?? item.NomeFornecedor ?? "Sem fornecedor")
                        </td>

                        <td>
                            @item.DataVencimento.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            @item.Descricao
                        </td>

                        <td>

                            <span class="badge bg-secondary">
                                @item.Categoria
                            </span>

                        </td>

                        <td class="fw-bold text-danger">
                            @item.Valor.ToString("C")
                        </td>

                        <td>

                            @if (!string.IsNullOrEmpty(item.UrlDocumento))
                            {
                            <a href="@item.UrlDocumento"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary px-2 py-1">

                                📄

                            </a>
                            }
                            else
                            {
                            <span class="text-muted small">
                                Sem nota
                            </span>
                            }

                        </td>

                        <td>

                            <span class="badge @statusClass">
                                @statusTexto
                            </span>

                        </td>

                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning px-2 py-1">

                                ✏

                            </a>

                            @if (!item.DataPagamento.HasValue)
    {
                            <button type="button"
                                    class="btn btn-sm btn-success px-2 py-1 btnBaixar"
                                    data-id="@item.Id">

                                ✔

                            </button>
    }

                            <form asp-action="Delete"
                                  method="post"
                                  class="d-inline">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button type="submit"
                                        class="btn btn-sm btn-danger px-2 py-1"
                                        onclick="return confirm('Deseja excluir esta conta?')">

                                    🗑

                                </button>

                            </form>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>

    <!-- MODAL BAIXA -->
    <div class="modal fade"
         id="modalBaixa"
         tabindex="-1">

        <div class="modal-dialog">

            <div class="modal-content">

                <form method="post"
                      id="formBaixa">

                    @Html.AntiForgeryToken()

                    <div class="modal-header">

                        <h5 class="modal-title">
                            Confirmar Pagamento
                        </h5>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body">

                        <input type="hidden"
                               name="id"
                               id="baixaId" />

                        <label class="form-label">
                            Data do pagamento
                        </label>

                        <input type="date"
                               name="dataPagamento"
                               class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" />

                        <small class="text-muted">
                            Se não alterar, será usada a data atual.
                        </small>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">

                            Cancelar

                        </button>

                        <button type="submit"
                                class="btn btn-success">

                            Confirmar Baixa

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // =========================================
        // MODAL BAIXA
        // =========================================

        const modalBaixa =
            new bootstrap.Modal(
                document.getElementById('modalBaixa')
            );

        document.addEventListener('click', function (e) {

            const botao =
                e.target.closest('.btnBaixar');

            if (!botao)
                return;

            const id =
                botao.dataset.id;

            document.getElementById('baixaId').value =
                id;

            document.getElementById('formBaixa').action =
                `/ContasPagar/Baixar`;

            modalBaixa.show();
        });
    // =========================================
    // FORNECEDOR
    // =========================================

        $('#fornecedorSelect').select2({

            theme: 'bootstrap-5',

            placeholder: 'Clique ou digite para buscar fornecedor...',

            minimumInputLength: 0,

            ajax: {

                url: '/EntradaEstoque/BuscarFornecedoresPaginado',

                dataType: 'json',

                delay: 150,

                data: function (params) {

                    return {

                        termo: params.term || '',
                        pagina: params.page || 1
                    };
                },

                processResults: function (data) {

                    return {

                        results: data.items.map(item => ({

                            id: item.id,
                            text: item.text

                        })),

                        pagination: {

                            more: data.pagination.more
                        }
                    };
                }
            }
        });

    // =========================================
    // MANTER FORNECEDOR SE FILTRADO
    // =========================================

        const fornecedorAtual = '@ViewBag.FornecedorId';
        const fornecedorTexto = '@ViewBag.FornecedorTexto';

        if (fornecedorAtual) {

            const option = new Option(
                fornecedorTexto,
                fornecedorAtual,
                true,
                true
            );

            $('#fornecedorSelect')
                .append(option)
                .trigger('change');
        }

    // =========================================
    // SCROLL INFINITO
    // =========================================

    let carregando = false;
    let skip = 10;
    let primeiraCarga = true;

    const container =
        document.getElementById('scrollPagar');

    container.addEventListener('scroll', async () => {

        if (primeiraCarga) {

            primeiraCarga = false;
            return;
        }

        if (carregando)
            return;

        if (
            container.scrollTop + container.clientHeight >=
            container.scrollHeight - 50
        ) {

            carregando = true;

            const fornecedorId =
                $('#fornecedorSelect').val() || '';

            const dataInicio =
                document.querySelector('[name="dataInicio"]').value;

            const dataFim =
                document.querySelector('[name="dataFim"]').value;

            const status =
                document.querySelector('[name="status"]').value;

            const url =
                `/ContasPagar/CarregarMais?skip=${skip}&fornecedorId=${encodeURIComponent(fornecedorId)}&dataInicio=${dataInicio}&dataFim=${dataFim}&status=${status}`;

            const response =
                await fetch(url);

            const dados =
                await response.json();

            if (dados.length === 0) {

                carregando = false;
                return;
            }

            const tabela =
                document.querySelector('#tabelaPagar tbody');

            dados.forEach(c => {

                let status = "";

                if (c.pago)
                    status = `<span class="badge bg-success">Pago</span>`;
                else if (c.vencido)
                    status = `<span class="badge bg-danger">Vencido</span>`;
                else if (c.vencendo)
                    status = `<span class="badge bg-warning text-dark">Vencendo</span>`;
                else
                    status = `<span class="badge bg-secondary">Pendente</span>`;

                const documento = c.documento
                    ? `
                        <a href="${c.documento}"
                           target="_blank"
                           class="btn btn-sm btn-outline-primary px-2 py-1">
                            📄
                        </a>
                    `
                    : `<span class="text-muted small">Sem nota</span>`;

                const linha = `

                    <tr>

                        <td>${c.fornecedor}</td>

                        <td>${c.vencimento}</td>

                        <td>${c.descricao ?? ''}</td>

                        <td>
                            <span class="badge bg-secondary">
                                ${c.categoria ?? ''}
                            </span>
                        </td>

                        <td class="fw-bold text-danger">
                            R$ ${c.valor}
                        </td>

                        <td>
                            ${documento}
                        </td>

                        <td>
                            ${status}
                        </td>

                       <td class="text-end">

                        <a href="/ContasPagar/Edit/${c.id}"
                           class="btn btn-sm btn-warning px-2 py-1">
                            ✏
                        </a>

                        ${!c.pago
                                            ? `
                            <button type="button"
                                    class="btn btn-sm btn-success px-2 py-1 btnBaixar"
                                    data-id="${c.id}">
                                ✔
                            </button>
                            `
                                            : ""
                                        }

                        <form action="/ContasPagar/Delete"
                              method="post"
                              class="d-inline">

                            <input type="hidden"
                                   name="id"
                                   value="${c.id}" />

                            <button type="submit"
                                    class="btn btn-sm btn-danger px-2 py-1"
                                    onclick="return confirm('Deseja excluir esta conta?')">

                                🗑

                            </button>

                        </form>

                    </td>
                    </tr>
                `;

                tabela.insertAdjacentHTML(
                    'beforeend',
                    linha
                );
            });

            skip += 20;

            carregando = false;
        }
    });

    </script>
