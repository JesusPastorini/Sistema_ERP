@model ControleEstoque.Models.Venda

@{
    ViewData["Title"] = "Nova Venda";
}

<!-- ✅ CSS CORRETO -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<div class="container-fluid" id="vendaContainer">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🛒 Realizar Nova Venda</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar ao Histórico</a>
    </div>

    <form asp-action="Create" method="post" id="formVenda">
        <div class="row">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- 🔹 DADOS -->
            <div class="col-md-4">
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-dark text-white"><h5>Dados Gerais</h5></div>
                    <div class="card-body">
                        <!-- Selecionar Cliente -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">

                                <label class="form-label fw-bold mb-0">
                                    Cliente
                                </label>

                                <a asp-controller="Clientes"
                                   asp-action="Create"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-primary">
                                    ➕ Novo Cliente
                                </a>

                            </div>

                            <select asp-for="ClienteId"
                                    class="form-select"
                                    asp-items="ViewBag.ClienteId"
                                    required>

                                <option value="">
                                    -- Selecione o Cliente --
                                </option>

                            </select>

                            <small class="text-muted">
                                Caso o cliente não exista, clique em "Novo Cliente".
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Forma de Pagamento</label>
                            <select asp-for="FormaPagamento" class="form-select" required>
                                <option value="Dinheiro">💵 Dinheiro</option>
                                <option value="Pix">📱 Pix</option>
                                <option value="Cartão">💳 Cartão</option>
                                <option value="Boleto">📄 Boleto</option>
                                <option value="Link">🔗 Link de pagamento</option>
                            </select>
                            <div id="condicaoBox" style="display:none;" class="mt-3">
                                <label class="fw-bold">Condição</label>
                                <select name="CondicaoPagamentoId" id="condicaoPagamento" class="form-control">
                                    <option value="">Selecione...</option>

                                    @if (ViewBag.Condicoes != null)
    {
        foreach (var item in ViewBag.Condicoes)
        {
                                    <option value="@item.Id"
                                            data-juros="@item.Juros"
                                            data-parcelas="@item.Parcelas"
                                            data-taxa="@item.TaxaOperadora">
                                        @item.Nome
                                    </option>
        }
    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 🔹 TOTAL -->
                <div class="card shadow-sm border-success bg-light border-0">
                    <div class="card-body text-center">
                        <h4 class="text-muted small fw-bold">TOTAL DA VENDA</h4>
                        <h1 class="display-4 fw-bold text-success" id="valorTotalDisplay">R$ 0,00</h1>
                        <input type="hidden" name="ValorTotal" id="ValorTotalInput" value="0" />
                        <button type="submit" class="btn btn-success btn-lg w-100 mt-3 shadow">🚀 Finalizar Venda</button>
                    </div>
                </div>
            </div>

            <!-- 🔹 ITENS -->
            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white"><h5>Itens da Venda</h5></div>
                    <div class="card-body">

                        <div class="row g-2 align-items-end mb-4 bg-light p-3 rounded">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">🔎 BUSCAR</label>
                                <select id="selectProdutoBusca" class="form-control"></select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-bold small">QTD</label>
                                <input type="number" id="inputQtd" class="form-control" step="1" min="1" />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label fw-bold small">PREÇO</label>
                                <input type="number" id="inputPreco" class="form-control" step="0.01" />
                            </div>

                            <div class="col-md-2">
                                <button type="button" id="btnAdicionar" class="btn btn-primary w-100 fw-bold">Adicionar</button>
                            </div>
                        </div>

                        <table class="table table-hover" id="tabelaItens">
                            <thead>
                                <tr>
                                    <th>Descrição</th>
                                    <th>Qtd</th>
                                    <th>Preço</th>
                                    <th>Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>

                        <div id="listaInputsEscondidos"></div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {

    <!-- ✅ JS CORRETO (ORDEM IMPORTA) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        let totalGeral = 0;
        let estoqueLocal = {};

        $(document).ready(function () {

            $('#selectProdutoBusca').select2({
                theme: 'bootstrap-5',
                placeholder: 'Digite ou clique para buscar...',
                minimumInputLength: 0,
                ajax: {
                    url: '/Vendas/BuscarProdutosPaginado',
                    dataType: 'json',
                    delay: 150,
                    data: function (params) {
                        return {
                            termo: params.term || '',
                            pagina: params.page || 1
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data.items.map(item => ({
                                id: item.id,
                                text: item.text,
                                estoque: item.estoque
                            })),
                            pagination: {
                                more: data.pagination.more
                            }
                        };
                    }
                }
            });

            const formaPagamento = document.querySelector('[name="FormaPagamento"]');
            const condicaoBox = document.getElementById('condicaoBox');

            formaPagamento.addEventListener('change', function () {
                const precisaCondicao = ["Cartão", "Boleto", "Link"];

                if (precisaCondicao.includes(this.value)) {
                    condicaoBox.style.display = "block";
                } else {
                    condicaoBox.style.display = "none";
                    document.getElementById('condicaoPagamento').value = "";
                }
            });
        });

        $(document).on('click', '#btnAdicionar', function () {

            const selected = $('#selectProdutoBusca').select2('data');

            if (!selected || selected.length === 0) {
                alert("Selecione um produto!");
                return;
            }

            const data = selected[0];
            const qtd = parseInt(document.getElementById('inputQtd').value);
            const preco = parseFloat(document.getElementById('inputPreco').value);

            if (isNaN(qtd) || qtd <= 0) {
                alert("Quantidade inválida!");
                return;
            }

            if (isNaN(preco) || preco <= 0) {
                alert("Preço inválido!");
                return;
            }

            const produtoId = data.id;
            let jaNaLista = estoqueLocal[produtoId] || 0;

            if (data.estoque !== undefined) {
                const disponivel = data.estoque - jaNaLista;

                if (disponivel <= 0) {
                    alert(`❌ Produto sem estoque disponível.`);
                    return;
                }

                if (qtd > disponivel) {
                    alert(`❌ Estoque insuficiente! Disponível: ${disponivel}`);
                    return;
                }
            }

            estoqueLocal[produtoId] = jaNaLista + qtd;

            const subtotal = qtd * preco;
            const idUnico = Date.now();

            $('#tabelaItens tbody').append(`
                <tr id="tr-${idUnico}">
                    <td>${data.text}</td>
                    <td>${qtd}</td>
                    <td>R$ ${preco.toFixed(2)}</td>
                    <td>R$ ${subtotal.toFixed(2)}</td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm"
                            onclick="removerItem(${idUnico}, ${subtotal}, ${produtoId}, ${qtd})">
                            X
                        </button>
                    </td>
                </tr>
            `);

            $('#listaInputsEscondidos').append(`
                <div id="cont-${idUnico}">
                    <input type="hidden" name="ProdutoId" value="${produtoId}" />
                    <input type="hidden" name="Quantidade" value="${qtd}" />
                    <input type="hidden" name="PrecoUnitario" value="${preco}" />
                </div>
            `);

            totalGeral += subtotal;
            atualizarTotal();

            $('#selectProdutoBusca').val(null).trigger('change');
            document.getElementById('inputPreco').value = "";
            document.getElementById('inputQtd').value = "1";
        });

        function removerItem(id, sub, prodId, qtd) {
            $(`#tr-${id}`).remove();
            $(`#cont-${id}`).remove();

            estoqueLocal[prodId] -= qtd;
            totalGeral -= sub;

            atualizarTotal();
        }

        function atualizarTotal() {

            let total = totalGeral;

            const select = document.getElementById('condicaoPagamento');

            if (select && select.selectedIndex > 0) {

                const selected = select.options[select.selectedIndex];

                const juros = parseFloat(selected.getAttribute('data-juros')) || 0;
                const taxa = parseFloat(selected.getAttribute('data-taxa')) || 0;
                const parcelas = parseInt(selected.getAttribute('data-parcelas')) || 1;

                // aplica juros
                if (juros > 0) {
                    total += total * (juros / 100);
                }

                // aplica taxa
                if (taxa > 0) {
                    total += total * (taxa / 100);
                }

                // 🔥 SE FOR PARCELADO
                if (parcelas > 1) {

                    const valorParcela = total / parcelas;

                    document.getElementById('valorTotalDisplay').innerText =
                        `${parcelas}x de ${valorParcela.toLocaleString('pt-BR', {
                            style: 'currency',
                            currency: 'BRL'
                        })}`;
                }
                else {
                    // pagamento à vista
                    document.getElementById('valorTotalDisplay').innerText =
                        total.toLocaleString('pt-BR', {
                            style: 'currency',
                            currency: 'BRL'
                        });
                }

            } else {
                // sem condição
                document.getElementById('valorTotalDisplay').innerText =
                    total.toLocaleString('pt-BR', {
                        style: 'currency',
                        currency: 'BRL'
                    });
            }

            // 🔥 BACKEND SEMPRE RECEBE TOTAL
            document.getElementById('ValorTotalInput').value =
                total.toFixed(2).replace('.', ',');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const select = document.getElementById('condicaoPagamento');

            if (select) {
                select.addEventListener('change', atualizarTotal);
            }
        });
    </script>
}