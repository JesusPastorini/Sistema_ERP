@model IEnumerable<ControleEstoque.Models.Venda>

    @{
    ViewData["Title"] = "Histórico de Vendas";
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        body {
            overflow-x: hidden;
        }

        .select2-results__options {
            max-height: 300px !important;
            overflow-y: auto !important;
        }
    </style>

    <div class="container-fluid">

        <!-- 🔹 HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2>
                📋 Histórico de Vendas
            </h2>

            <a asp-action="Create"
               class="btn btn-primary">

                ➕ Nova Venda

            </a>

        </div>

        <!-- 🔎 FILTRO -->
        <form method="get"
              class="mb-4">

            <div class="row g-2 align-items-end">

                <div class="col-md-3">

                    <label class="form-label">
                        Data Inicial
                    </label>

                    <input type="date"
                           name="dataInicio"
                           class="form-control"
                           value="@ViewBag.DataInicio" />

                </div>

                <div class="col-md-3">

                    <label class="form-label">
                        Data Final
                    </label>

                    <input type="date"
                           name="dataFim"
                           class="form-control"
                           value="@ViewBag.DataFim" />

                </div>

                <!-- CLIENTE -->
                <div class="col-md-4">

                    <label class="form-label">
                        Cliente
                    </label>

                    <select id="clienteSelect"
                            name="cliente"
                            class="form-select">
                    </select>

                </div>

                <div class="col-md-2 d-flex align-items-end">

                    <button class="btn btn-dark btn-sm w-100"
                            style="height: 38px;">

                        🔍

                    </button>

                </div>

            </div>

        </form>

        <!-- 📋 TABELA -->
        <div class="card shadow-sm border-0">

            <div class="table-responsive"
                 style="max-height: 500px; overflow-y: auto;"
                 id="scrollContainer">

                <table class="table table-hover align-middle mb-0"
                       id="tabelaVendas">

                    <thead class="table-dark">

                        <tr>

                            <th>
                                Data
                            </th>

                            <th>
                                Cliente
                            </th>

                            <th>
                                Vendedor
                            </th>

                            <th>
                                Total
                            </th>

                            <th>
                                Pagamento
                            </th>

                            <th>
                                Condição
                            </th>

                            <th></th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                    {
                        var badgeClass = item.FormaPagamento switch
                        {
                            "Dinheiro" => "bg-success",
                            "Pix" => "bg-primary",
                            "Cartão" => "bg-warning text-dark",
                            "Boleto" => "bg-secondary",
                            _ => "bg-dark"
                        };

                        <tr>

                            <td>
                                @item.DataVenda.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.Cliente?.Nome
                            </td>

                            <td>
                                @item.Usuario?.Nome
                            </td>

                            <td class="fw-bold text-success">
                                @item.ValorTotal.ToString("C")
                            </td>

                            <td>

                                <span class="badge @badgeClass">
                                    @item.FormaPagamento
                                </span>

                            </td>

                            <td>

                                @(item.CondicaoPagamento != null
                                    ? $"{item.CondicaoPagamento.Parcelas}x"
                                    : "-")

                            </td>

                            <td class="text-end">

                                <a asp-action="Detalhes"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info text-white px-3 py-1">

                                    👁

                                </a>

                            </td>

                        </tr>
                    }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    @section Scripts {

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        <script>

            // =========================================
            // CLIENTE
            // =========================================

            $('#clienteSelect').select2({

                theme: 'bootstrap-5',

                placeholder: 'Buscar cliente...',

                minimumInputLength: 0,

                ajax: {

                    url: '/Vendas/BuscarClientesPaginado',

                    dataType: 'json',

                    delay: 150,

                    data: function (params) {

                        return {

                            termo: params.term || '',
                            pagina: params.page || 1
                        };
                    },

                    processResults: function (data) {

                        return {

                            results: data.items.map(item => ({

                                id: item.id,
                                text: item.text

                            })),

                            pagination: {

                                more: data.pagination.more
                            }
                        };
                    }
                }
            });

            // =========================================
            // SCROLL INFINITO
            // =========================================

            let carregando = false;
            let skip = 10;

            const container =
                document.getElementById('scrollContainer');

            container.addEventListener('scroll', async () => {

                if (carregando)
                    return;

                if (
                    container.scrollTop + container.clientHeight >=
                    container.scrollHeight - 50
                ) {

                    carregando = true;

                    const url =
                        `/Vendas/CarregarMais?skip=${skip}`;

                    const response =
                        await fetch(url);

                    const dados =
                        await response.json();

                    if (dados.length === 0) {

                        carregando = false;
                        return;
                    }

                    const tabela =
                        document.querySelector('#tabelaVendas tbody');

                    dados.forEach(v => {

                        let badgeClass = "bg-dark";

                        if (v.pagamento === "Dinheiro")
                            badgeClass = "bg-success";

                        if (v.pagamento === "Pix")
                            badgeClass = "bg-primary";

                        if (v.pagamento === "Cartão")
                            badgeClass = "bg-warning text-dark";

                        if (v.pagamento === "Boleto")
                            badgeClass = "bg-secondary";

                        const linha = `

                                <tr>

                                    <td>${v.data}</td>

                                    <td>${v.cliente}</td>

                                    <td>${v.usuario}</td>

                                    <td class="fw-bold text-success">
                                        R$ ${v.total}
                                    </td>

                                    <td>

                                        <span class="badge ${badgeClass}">
                                            ${v.pagamento}
                                        </span>

                                    </td>

                                    <td>
                                        ${v.parcelas}
                                    </td>

                                    <td class="text-end">

                                        <a href="/Vendas/Detalhes/${v.id}"
                                           class="btn btn-sm btn-info text-white px-3 py-1">

                                            👁

                                        </a>

                                    </td>

                                </tr>
                            `;

                        tabela.insertAdjacentHTML(
                            'beforeend',
                            linha
                        );
                    });

                    skip += 20;

                    carregando = false;
                }
            });

        </script>

    }
