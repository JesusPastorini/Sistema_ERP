@model IEnumerable<ControleEstoque.Models.Venda>


        <!-- 🔹 HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>📋 Histórico de Vendas</h2>

            <a asp-action="Create" class="btn btn-primary">
                ➕ Nova Venda
            </a>
        </div>

        <!-- 🔎 FILTRO -->
        <form method="get" class="mb-4">
            <div class="row g-2 align-items-end">

                <div class="col-md-3">
                    <label class="form-label">Data Inicial</label>
                    <input type="date" name="dataInicio"
                           class="form-control"
                           value="@ViewBag.DataInicio" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Data Final</label>
                    <input type="date" name="dataFim"
                           class="form-control"
                           value="@ViewBag.DataFim" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Cliente</label>
                    <input type="text" name="cliente"
                           class="form-control"
                           placeholder="Nome do cliente..."
                           value="@ViewBag.Cliente" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-dark btn-sm w-100" style="height: 38px;">
                        🔍
                    </button>
                </div>

            </div>
        </form>

        <!-- 📋 TABELA -->
        <div class="card shadow-sm border-0">
            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;" id="scrollContainer">
                <table class="table table-hover align-middle mb-0" id="tabelaVendas">

                    <thead class="table-dark">
                        <tr>
                            <th>Data</th>
                            <th>Cliente</th>
                            <th>Vendedor</th>
                            <th>Total</th>
                            <th>Pagamento</th>
                            <th>Condição</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                    {
                        var badgeClass = item.FormaPagamento switch
                        {
                            "Dinheiro" => "bg-success",
                            "Pix" => "bg-primary",
                            "Cartão" => "bg-warning text-dark",
                            "Boleto" => "bg-secondary",
                            _ => "bg-dark"
                        };

                        <tr>
                            <td>@item.DataVenda.ToString("dd/MM/yyyy")</td>
                            <td>@item.Cliente?.Nome</td>
                            <td>@item.Usuario?.Nome</td>

                            <td class="fw-bold text-success">
                                @item.ValorTotal.ToString("C")
                            </td>

                            <td>
                                <span class="badge @badgeClass">
                                    @item.FormaPagamento
                                </span>
                            </td>

                            <td>
                                @(item.CondicaoPagamento != null
                                    ? $"{item.CondicaoPagamento.Parcelas}x"
                                    : "-")
                            </td>

                            <td class="text-end">
                                <a asp-action="Detalhes"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info text-white px-3 py-1">
                                    👁
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>

                </table>
            </div>
        </div>

    <script>
        let carregando = false;
        let skip = 10;
        let primeiraCarga = true; // 🔥 CONTROLE

        const container = document.getElementById('scrollContainer');

        container.addEventListener('scroll', async () => {

            // 🔥 EVITA DISPARO NA PRIMEIRA RENDERIZAÇÃO
            if (primeiraCarga) {
                primeiraCarga = false;
                return;
            }

            if (carregando) return;

            if (container.scrollTop + container.clientHeight >= container.scrollHeight - 50) {

                carregando = true;

                const url = `/Vendas/CarregarMais?skip=${skip}`;

                const response = await fetch(url);
                const dados = await response.json();

                // 🔥 SE NÃO TEM MAIS DADOS → PARA DE CHAMAR
                if (dados.length === 0) return;

                const tabela = document.querySelector('#tabelaVendas tbody');

                dados.forEach(v => {

                    let badgeClass = "bg-dark";

                    if (v.pagamento === "Dinheiro") badgeClass = "bg-success";
                    if (v.pagamento === "Pix") badgeClass = "bg-primary";
                    if (v.pagamento === "Cartão") badgeClass = "bg-warning text-dark";
                    if (v.pagamento === "Boleto") badgeClass = "bg-secondary";

                    const linha = `
                    <tr>
                        <td>${v.data}</td>
                        <td>${v.cliente}</td>
                        <td>${v.usuario}</td>
                        <td class="fw-bold text-success">R$ ${v.total}</td>
                        <td><span class="badge ${badgeClass}">${v.pagamento}</span></td>
                        <td>${v.parcelas}</td>
                        <td class="text-end">
                            <a href="/Vendas/Detalhes/${v.id}" class="btn btn-sm btn-info text-white px-3 py-1">👁</a>
                        </td>
                    </tr>
                `;

                    tabela.insertAdjacentHTML('beforeend', linha);
                });

                skip += 20;
                carregando = false;
            }
        });
    </script>