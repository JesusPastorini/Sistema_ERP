@model List<Produto>

    @{
    ViewData["Title"] = "Produtos";
    }

    <!-- 🔹 HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📦 Produtos</h2>

        <a asp-action="Create" class="btn btn-primary">
            ➕ Criar Produto
        </a>
    </div>

    <!-- 🔎 FILTRO -->
    <form method="get" class="mb-4">
        <div class="row g-2 align-items-end">

            <div class="col-md-10">
                <label class="form-label">Buscar</label>
                <input type="text" name="busca"
                       class="form-control"
                       placeholder="Nome, categoria, fornecedor..."
                       value="@ViewBag.Busca" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-dark btn-sm w-100" style="height: 38px;">
                    🔍
                </button>
            </div>

        </div>
    </form>

    <!-- 📦 TABELA -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive"
             style="max-height: calc(100vh - 220px); overflow-y: auto;"
             id="scrollContainerProdutos">

            <table class="table table-hover align-middle mb-0" id="tabelaProdutos">

                <thead class="table-dark">
                    <tr>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Fornecedor</th>
                        <th>Estoque</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                {
                    var estoqueClass = item.QuantidadeEstoque > 5 ? "bg-success"
                                        : item.QuantidadeEstoque > 0 ? "bg-warning text-dark"
                                        : "bg-danger";

                    <tr>
                        <td>
                            <strong>@item.TipoMadeira</strong><br />
                            <small class="text-muted">@item.Dimensoes</small>
                        </td>

                        <td>@item.Categoria</td>

                        <td>
                            @(item.Fornecedor?.NomeFantasia ?? "N/A")
                        </td>

                        <td>
                            <span class="badge @estoqueClass">
                                @item.QuantidadeEstoque
                            </span>
                        </td>

                        <td class="text-end">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-info text-white px-2 py-1">
                                👁
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning px-2 py-1">
                                ✏
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger px-2 py-1">
                                🗑
                            </a>

                        </td>
                    </tr>
                }
                </tbody>

            </table>
        </div>
    </div>

    <script>
    let carregando = false;
    let skip = 10;
    let primeiraCarga = true;

    const container = document.getElementById('scrollContainerProdutos');

    container.addEventListener('scroll', async () => {

        if (primeiraCarga) {
            primeiraCarga = false;
            return;
        }

        if (carregando) return;

        if (container.scrollTop + container.clientHeight >= container.scrollHeight - 50) {

            carregando = true;

            const url = `/Produtos/CarregarMais?skip=${skip}`;

            const response = await fetch(url);
            const dados = await response.json();

            if (dados.length === 0) return;

            const tabela = document.querySelector('#tabelaProdutos tbody');

            dados.forEach(p => {

                let estoqueClass = "bg-danger";

                if (p.estoque > 5) estoqueClass = "bg-success";
                else if (p.estoque > 0) estoqueClass = "bg-warning text-dark";

                const linha = `
                    <tr>
                        <td>
                            <strong>${p.nome}</strong><br/>
                            <small class="text-muted">${p.dimensoes}</small>
                        </td>

                        <td>${p.categoria}</td>

                        <td>${p.fornecedor ?? 'N/A'}</td>

                        <td>
                            <span class="badge ${estoqueClass}">
                                ${p.estoque}
                            </span>
                        </td>

                        <td class="text-end">
                            <a href="/Produtos/Details/${p.id}" class="btn btn-sm btn-info text-white px-2 py-1">👁</a>
                            <a href="/Produtos/Edit/${p.id}" class="btn btn-sm btn-warning px-2 py-1">✏</a>
                            <a href="/Produtos/Delete/${p.id}" class="btn btn-sm btn-danger px-2 py-1">🗑</a>
                        </td>
                    </tr>
                `;

                tabela.insertAdjacentHTML('beforeend', linha);
            });

            skip += 20;
            carregando = false;
        }
    });
    </script>