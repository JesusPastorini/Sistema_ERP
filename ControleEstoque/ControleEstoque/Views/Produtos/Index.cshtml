@model List<Produto>

    @{
    ViewData["Title"] = "Produtos";
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📦 Produtos</h2>

        <a asp-action="Create" class="btn btn-primary">
            ➕ Criar Produto
        </a>
    </div>

    <!-- 🔎 BUSCA -->
    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="busca" class="form-control"
                   placeholder="Buscar produto..."
                   value="@ViewBag.Busca" />

            <button class="btn btn-dark">🔍 Buscar</button>
        </div>
    </form>

    <!-- 📦 LISTA -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Fornecedor</th>
                        <th>Estoque</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.TipoMadeira</strong><br />
                            <small class="text-muted">@item.Dimensoes</small>
                        </td>

                        <td>@item.Categoria</td>

                        <td>
                            @(item.Fornecedor?.NomeFantasia ?? "N/A")
                        </td>

                        <!-- ESTOQUE COLORIDO -->
                        <td>
                            <span class="badge @(item.QuantidadeEstoque > 5 ? "bg-success" :
                                                item.QuantidadeEstoque > 0 ? "bg-warning text-dark" :
                                                "bg-danger")">
                                @item.QuantidadeEstoque
                            </span>
                        </td>

                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-info text-white">
                                👁
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">
                                ✏
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">
                                🗑
                            </a>
                        </td>
                    </tr>
                }
                </tbody>

            </table>
        </div>
    </div>
