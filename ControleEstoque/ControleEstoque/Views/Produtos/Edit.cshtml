@model Produto

@{
    ViewData["Title"] = "Editar Produto";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>
        ✏ Editar Produto
    </h2>

    <a asp-action="Index"
       class="btn btn-secondary">

        ← Voltar

    </a>

</div>

<div class="card shadow-sm border-0">

    <div class="card-header bg-warning">

        <h5 class="mb-0">
            Dados do Produto
        </h5>

    </div>

    <div class="card-body">

        <form asp-action="Edit"
              method="post">

            <input type="hidden"
                   asp-for="Id" />

            <div class="row">

                <!-- CATEGORIA -->
                <div class="col-md-4 mb-3">

                    <label asp-for="Categoria"
                           class="form-label fw-bold">

                        Categoria

                    </label>

                    <input asp-for="Categoria"
                           class="form-control" />

                </div>

                <!-- TIPO MADEIRA -->
                <div class="col-md-4 mb-3">

                    <label asp-for="TipoMadeira"
                           class="form-label fw-bold">

                        Produto

                    </label>

                    <input asp-for="TipoMadeira"
                           class="form-control" />

                </div>

                <!-- FORNECEDOR -->
                <div class="col-md-4 mb-3">

                    <label asp-for="FornecedorId"
                           class="form-label fw-bold">

                        Fornecedor

                    </label>

                    <select asp-for="FornecedorId"
                            asp-items="ViewBag.Fornecedores"
                            class="form-select">

                        <option value="">
                            Selecione um fornecedor
                        </option>

                    </select>

                </div>

            </div>

            <!-- DESCRIÇÃO -->
            <div class="mb-3">

                <label asp-for="Descricao"
                       class="form-label fw-bold">

                    Descrição

                </label>

                <textarea asp-for="Descricao"
                          rows="4"
                          class="form-control">
                </textarea>

            </div>

            <div class="row">

                <!-- DIMENSÕES -->
                <div class="col-md-4 mb-3">

                    <label asp-for="Dimensoes"
                           class="form-label fw-bold">

                        Dimensões

                    </label>

                    <input asp-for="Dimensoes"
                           class="form-control" />

                </div>

                <!-- UNIDADE -->
                <div class="col-md-4 mb-3">

                    <label asp-for="UnidadeMedida"
                           class="form-label fw-bold">

                        Unidade

                    </label>

                    <input asp-for="UnidadeMedida"
                           class="form-control" />

                </div>

                <!-- ESTOQUE -->
                <div class="col-md-4 mb-3">

                    <label asp-for="QuantidadeEstoque"
                           class="form-label fw-bold">

                        Estoque Atual

                    </label>

                    <input asp-for="QuantidadeEstoque"
                           type="number"
                           class="form-control" />

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-outline-secondary">

                    Cancelar

                </a>

                <button type="submit"
                        class="btn btn-success">

                    💾 Salvar Alterações

                </button>

            </div>

        </form>

    </div>

</div>