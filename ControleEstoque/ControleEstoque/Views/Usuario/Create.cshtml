@model ControleEstoque.Models.Usuario

@{
    ViewData["Title"] = "Novo Usuário";
}

<div class="container-fluid">

    <div class="card shadow-lg border-0 mt-4">

        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">👤 Novo Usuário</h3>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="row">

                    <!-- Nome -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            Nome
                        </label>

                        <input asp-for="Nome"
                               class="form-control form-control-lg"
                               placeholder="Nome completo" />

                        <span asp-validation-for="Nome"
                              class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            Email
                        </label>

                        <input asp-for="Email"
                               class="form-control form-control-lg"
                               placeholder="usuario@email.com" />

                        <span asp-validation-for="Email"
                              class="text-danger"></span>
                    </div>

                    <!-- Senha -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            Senha
                        </label>

                        <input asp-for="Senha"
                               type="password"
                               class="form-control form-control-lg"
                               placeholder="Digite a senha" />

                        <span asp-validation-for="Senha"
                              class="text-danger"></span>
                    </div>

                    <!-- Confirmar -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            Confirmar Senha
                        </label>

                        <input asp-for="ConfirmarSenha"
                               type="password"
                               class="form-control form-control-lg"
                               placeholder="Repita a senha" />

                        <span asp-validation-for="ConfirmarSenha"
                              class="text-danger"></span>
                    </div>

                    <!-- Permissão -->
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">
                            Permissão
                        </label>

                        <select asp-for="PermissaoId"
                                asp-items="ViewBag.PermissaoId"
                                class="form-select form-select-lg">

                            <option value="">
                                -- Selecione --
                            </option>

                        </select>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-3">

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg px-5">
                        Voltar
                    </a>

                    <button type="submit"
                            class="btn btn-success btn-lg px-5">
                        💾 Salvar Usuário
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>