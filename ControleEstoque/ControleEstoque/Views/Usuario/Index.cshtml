@model List<ControleEstoque.Models.Usuario>

    @{
    ViewData["Title"] = "Usuários";
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👤 Usuários</h2>

        <a asp-action="Create" class="btn btn-primary">
            ➕ Novo Usuário
        </a>
    </div>

    <!-- 🔎 BUSCA -->
    <form method="get" class="mb-4">
        <div class="input-group">

            <input type="text"
                   name="busca"
                   class="form-control"
                   placeholder="Buscar por nome ou email..."
                   value="@ViewBag.Busca" />

            <button class="btn btn-dark">
                🔍 Buscar
            </button>

        </div>
    </form>

    <!-- 📋 LISTA -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Usuário</th>
                        <th>Email</th>
                        <th>Perfil</th>
                        <th width="150"></th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                    <tr>

                        <td>
                            <strong>@item.Nome</strong>
                        </td>

                        <td>
                            <small class="text-muted">
                                @item.Email
                            </small>
                        </td>

                        <td>
                            <span class="badge bg-primary">
                                @item.Permissao?.NomePerfil
                            </span>
                        </td>

                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">
                                ✏
                            </a>

                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#excluirModal"
                                    data-id="@item.Id">
                                🗑
                            </button>

                        </td>

                    </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center p-4 text-muted">
                            Nenhum usuário encontrado.
                        </td>
                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>
    <!-- MODAL EXCLUIR -->

    <div class="modal fade"
         id="excluirModal"
         tabindex="-1">

        <div class="modal-dialog">

            <div class="modal-content border-0 shadow">

                <form asp-action="Delete"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div class="modal-header bg-danger text-white">

                        <h5 class="modal-title">
                            🗑 Excluir Usuário
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body text-center">

                        <input type="hidden"
                               id="usuarioIdExcluir"
                               name="id" />

                        <div class="alert alert-warning">

                            Tem certeza que deseja excluir este usuário?

                        </div>

                        <h5 id="usuarioNomeExcluir"></h5>

                        <p class="text-muted"
                           id="usuarioEmailExcluir">
                        </p>

                        <span class="badge bg-primary"
                              id="usuarioPerfilExcluir">
                        </span>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">

                            Cancelar

                        </button>

                        <button type="submit"
                                class="btn btn-danger">

                            🗑 Confirmar Exclusão

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <script>

const excluirModal =
    document.getElementById('excluirModal');

excluirModal.addEventListener('show.bs.modal', async function (event) {

    const button = event.relatedTarget;

    const id =
        button.getAttribute('data-id');

    const dados =
        await fetch(`/Usuario/ObterUsuario?id=${id}`)
            .then(r => r.json());

    document.getElementById('usuarioIdExcluir').value =
        dados.id;

    document.getElementById('usuarioNomeExcluir').innerText =
        dados.nome;

    document.getElementById('usuarioEmailExcluir').innerText =
        dados.email;

    document.getElementById('usuarioPerfilExcluir').innerText =
        dados.perfil;
});

    </script>