@model CondicaoPagamento

@{
    ViewData["Title"] = "Editar Condição de Pagamento";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>
        ✏ Editar Condição de Pagamento
    </h2>

    <a asp-action="Index"
       class="btn btn-secondary">

        ← Voltar

    </a>

</div>

<div class="card shadow-sm border-0">

    <div class="card-header bg-warning">

        <h5 class="mb-0">
            Dados da Condição
        </h5>

    </div>

    <div class="card-body">

        <form asp-action="Edit"
              method="post">

            <input type="hidden"
                   asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger">
            </div>

            <div class="row">

                <!-- NOME -->
                <div class="col-md-8 mb-3">

                    <label asp-for="Nome"
                           class="form-label fw-bold">

                        Nome

                    </label>

                    <input asp-for="Nome"
                           class="form-control"
                           placeholder="Ex: Cartão Visa 3x" />

                    <span asp-validation-for="Nome"
                          class="text-danger">
                    </span>

                </div>

                <!-- TIPO -->
                <div class="col-md-4 mb-3">

                    <label asp-for="Tipo"
                           class="form-label fw-bold">

                        Tipo

                    </label>

                    <select asp-for="Tipo"
                            class="form-select">

                        <option value="Cartao">
                            💳 Cartão
                        </option>

                        <option value="Boleto">
                            📄 Boleto
                        </option>

                        <option value="Link">
                            🔗 Link de Pagamento
                        </option>

                    </select>

                    <span asp-validation-for="Tipo"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="row">

                <!-- PARCELAS -->
                <div class="col-md-4 mb-3">

                    <label asp-for="Parcelas"
                           class="form-label fw-bold">

                        Parcelas

                    </label>

                    <input asp-for="Parcelas"
                           type="number"
                           min="1"
                           class="form-control" />

                    <span asp-validation-for="Parcelas"
                          class="text-danger">
                    </span>

                </div>

                <!-- JUROS -->
                <div class="col-md-4 mb-3">

                    <label asp-for="Juros"
                           class="form-label fw-bold">

                        Juros (%)

                    </label>

                    <input asp-for="Juros"
                           type="number"
                           step="0.01"
                           class="form-control" />

                    <span asp-validation-for="Juros"
                          class="text-danger">
                    </span>

                </div>

                <!-- TAXA -->
                <div class="col-md-4 mb-3">

                    <label asp-for="TaxaOperadora"
                           class="form-label fw-bold">

                        Taxa Operadora (%)

                    </label>

                    <input asp-for="TaxaOperadora"
                           type="number"
                           step="0.01"
                           class="form-control" />

                    <span asp-validation-for="TaxaOperadora"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="row">

                <!-- DIAS -->
                <div class="col-md-4 mb-3">

                    <label asp-for="DiasRecebimento"
                           class="form-label fw-bold">

                        Dias para Receber

                    </label>

                    <input asp-for="DiasRecebimento"
                           type="number"
                           min="0"
                           class="form-control" />

                    <span asp-validation-for="DiasRecebimento"
                          class="text-danger">
                    </span>

                </div>

                <!-- RESUMO -->
                <div class="col-md-8 mb-3">

                    <label class="form-label fw-bold">

                        Resumo da Condição

                    </label>

                    <div class="border rounded p-3 bg-light">

                        <div class="row text-center">

                            <div class="col-md-4">

                                <strong>Tipo</strong>

                                <div class="mt-1">
                                    @Model.Tipo
                                </div>

                            </div>

                            <div class="col-md-4">

                                <strong>Parcelas</strong>

                                <div class="mt-1">
                                    @Model.Parcelas x
                                </div>

                            </div>

                            <div class="col-md-4">

                                <strong>Recebimento</strong>

                                <div class="mt-1">
                                    @Model.DiasRecebimento dias
                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-outline-secondary">

                    Cancelar

                </a>

                <button type="submit"
                        class="btn btn-success">

                    💾 Salvar Alterações

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}