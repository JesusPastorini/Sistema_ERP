@model ControleEstoque.Models.CondicaoPagamento

@{
    ViewData["Title"] = "Editar Condição";
}

<div class="container mt-4">
    <h2>✏️ Editar Condição</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <input asp-for="Nome" class="form-control mb-2" />

        <select asp-for="Tipo" class="form-control mb-2">
            <option value="Cartao">💳 Cartão</option>
            <option value="Boleto">📄 Boleto</option>
            <option value="Link">🔗 Link</option>
        </select>

        <input asp-for="Parcelas" type="number" class="form-control mb-2" />

        <input asp-for="Juros" type="number" step="0.01" class="form-control mb-2" />

        <input asp-for="TaxaOperadora" type="number" step="0.01" class="form-control mb-2" />

        <input asp-for="DiasRecebimento" type="number" class="form-control mb-2" />

        <button class="btn btn-success">Salvar</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>