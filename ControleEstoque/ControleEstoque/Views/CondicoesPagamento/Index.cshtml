@model IEnumerable<ControleEstoque.Models.CondicaoPagamento>

    @{
    ViewData["Title"] = "Condições de Pagamento";
    }

    <div class="container mt-4">
        <h2>💳 Condições de Pagamento</h2>

        <a asp-action="Create" class="btn btn-primary mb-3">
            ➕ Nova Condição
        </a>

        <table class="table table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Parcelas</th>
                    <th>Juros</th>
                    <th>Taxa</th>
                    <th>Dias</th>
                    <th style="width:180px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nome</td>
                    <td>@item.Tipo</td>
                    <td>@item.Parcelas</td>
                    <td>@item.Juros %</td>
                    <td>@item.TaxaOperadora %</td>
                    <td>@item.DiasRecebimento</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
