@model ControleEstoque.Models.CondicaoPagamento

@{
    ViewData["Title"] = "Detalhes";
}

<div class="container mt-4">
    <h2>📄 Detalhes da Condição</h2>

    <div class="card p-3">
        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>Tipo:</strong> @Model.Tipo</p>
        <p><strong>Parcelas:</strong> @Model.Parcelas</p>
        <p><strong>Juros:</strong> @Model.Juros %</p>
        <p><strong>Taxa Operadora:</strong> @Model.TaxaOperadora %</p>
        <p><strong>Dias para Receber:</strong> @Model.DiasRecebimento</p>
    </div>

    <a asp-action="Index" class="btn btn-secondary mt-3">Voltar</a>
</div>