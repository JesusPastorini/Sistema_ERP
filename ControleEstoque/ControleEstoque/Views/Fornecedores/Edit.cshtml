@model Fornecedor

@{
    ViewData["Title"] = "Novo Fornecedor";
}

<div class="card shadow-sm border-0">

    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">🏭 Cadastro de Fornecedor</h5>
    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">
                        Nome Fantasia
                    </label>

                    <input asp-for="NomeFantasia"
                           class="form-control form-control-lg" />

                    <span asp-validation-for="NomeFantasia"
                          class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">
                        Razão Social
                    </label>

                    <input asp-for="RazaoSocial"
                           class="form-control form-control-lg" />

                    <span asp-validation-for="RazaoSocial"
                          class="text-danger"></span>
                </div>

            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        CNPJ
                    </label>

                    <input asp-for="Cnpj"
                           class="form-control form-control-lg" />

                    <span asp-validation-for="Cnpj"
                          class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Telefone
                    </label>

                    <input asp-for="Telefone"
                           class="form-control form-control-lg" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Email
                    </label>

                    <input asp-for="Email"
                           class="form-control form-control-lg" />

                    <span asp-validation-for="Email"
                          class="text-danger"></span>
                </div>

            </div>

            <hr />

            <h5 class="mb-3">📍 Endereço</h5>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">
                        Rua
                    </label>

                    <input asp-for="Rua"
                           class="form-control form-control-lg" />
                </div>

                <div class="col-md-2 mb-3">
                    <label class="form-label fw-bold">
                        Número
                    </label>

                    <input asp-for="Numero"
                           class="form-control form-control-lg" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">
                        Bairro
                    </label>

                    <input asp-for="Bairro"
                           class="form-control form-control-lg" />
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">
                        Cidade
                    </label>

                    <input asp-for="Cidade"
                           class="form-control form-control-lg" />
                </div>

            </div>

            <hr />

            <div class="text-end">

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancelar
                </a>

                <button type="submit"
                        class="btn btn-warning btn-lg">
                    ✏ Atualizar
                </button>

            </div>

        </form>

    </div>

</div>