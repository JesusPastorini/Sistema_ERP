@model IEnumerable<Fornecedor>

@{
    ViewData["Title"] = "Fornecedores";
}
<h2 class="mb-4">Lista de Fornecedores</h2>

<div class="mt-4">
    
    <div class="mb-3">      
        <a asp-action="Create" class="btn btn-success btn-lg mt-2">
            Novo Fornecedor
        </a>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>CNPJ</th>
                <th>Telefone</th>
                <th>Email</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NomeFantasia</td>
                    <td>@item.Cnpj</td>
                    <td>@item.Telefone</td>
                    <td>@item.Email</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>