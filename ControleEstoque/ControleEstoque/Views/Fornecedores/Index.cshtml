@model List<Fornecedor>

    @{
    ViewData["Title"] = "Fornecedores";
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <style>

        .select2-container {
            width: 100% !important;
        }

        .select2-container--bootstrap-5 .select2-selection {
            min-height: 38px;
        }

        .select2-dropdown {
            z-index: 9999;
        }

        body {
            overflow-x: hidden;
        }

        .form-control:focus,
        .form-select:focus,
        .select2-container--bootstrap-5 .select2-selection:focus,
        .select2-container--bootstrap-5.select2-container--focus .select2-selection {
            border-color: #ced4da !important;
            box-shadow: none !important;
        }
    </style>

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            🏭 Fornecedores
        </h2>

        <a asp-action="Create"
           class="btn btn-primary">

            ➕ Novo Fornecedor

        </a>

    </div>

    <!-- FILTRO -->
    <form method="get" class="mb-4">

        <div class="row g-2 align-items-end">

            <div class="col-md-10">

                <label class="form-label fw-bold">
                    Buscar Fornecedor
                </label>

                <input type="text"
                       name="busca"
                       class="form-control"
                       placeholder="Digite nome fantasia, razão social ou CNPJ..."
                       value="@ViewBag.Busca" />

            </div>

            <div class="col-md-2 d-flex align-items-end">

                <button class="btn btn-dark btn-sm w-100"
                        style="height: 38px;">

                    🔍

                </button>

            </div>

        </div>

    </form>

    <!-- TABELA -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive"
             style="max-height: calc(100vh - 240px); overflow-y: auto;">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>Fornecedor</th>
                        <th>CNPJ</th>
                        <th>Telefone</th>
                        <th>Email</th>
                        <th></th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                {
                    <tr>

                        <td>

                            <strong>
                                @item.NomeFantasia
                            </strong>

                            <br />

                            <small class="text-muted">
                                @item.RazaoSocial
                            </small>

                        </td>

                        <td>

                            <span class="badge bg-secondary">
                                @item.Cnpj
                            </span>

                        </td>

                        <td>

                            @(string.IsNullOrWhiteSpace(item.Telefone)
                                ? "-"
                                : item.Telefone)

                        </td>

                        <td>

                            <small class="text-muted">

                                @(string.IsNullOrWhiteSpace(item.Email)
                                    ? "-"
                                    : item.Email)

                            </small>

                        </td>

                        <td class="text-end">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning px-2 py-1">

                                ✏

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger px-2 py-1">

                                🗑

                            </a>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>
