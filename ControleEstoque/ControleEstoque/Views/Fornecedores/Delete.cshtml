@model Fornecedor

@{
    ViewData["Title"] = "Excluir Fornecedor";
}

<div class="card shadow-sm border-0">

    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">🗑 Excluir Fornecedor</h5>
    </div>

    <div class="card-body">

        <div class="alert alert-warning">

            Tem certeza que deseja excluir este fornecedor?

        </div>

        <dl class="row">

            <dt class="col-sm-3">Fornecedor</dt>
            <dd class="col-sm-9">@Model.NomeFantasia</dd>

            <dt class="col-sm-3">Razão Social</dt>
            <dd class="col-sm-9">@Model.RazaoSocial</dd>

            <dt class="col-sm-3">CNPJ</dt>
            <dd class="col-sm-9">@Model.Cnpj</dd>

            <dt class="col-sm-3">Telefone</dt>
            <dd class="col-sm-9">@Model.Telefone</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

        </dl>

        <hr />

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <div class="text-end">

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>

                <button type="submit"
                        class="btn btn-danger">
                    🗑 Confirmar Exclusão
                </button>

            </div>

        </form>

    </div>

</div>