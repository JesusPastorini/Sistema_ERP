@model IEnumerable<ControleEstoque.Models.Orcamento>

    @{
    ViewData["Title"] = "Orçamentos";
    }

    <div class="d-flex justify-content-between mb-4">
        <h2>📄 Orçamentos</h2>

        <a asp-action="Create"
           class="btn btn-success">
            + Novo Orçamento
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <table class="table table-hover">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th>Data</th>
                        <th>Total</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>

                        <td>@item.Cliente?.Nome</td>

                        <td>
                            @item.DataOrcamento
                            .ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            @item.ValorTotal.ToString("C")
                        </td>

                        <td>
                            <span class="badge bg-primary">
                                @item.Status
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">
                                Visualizar
                            </a>
                        </td>
                    </tr>
                }

                </tbody>

            </table>

        </div>
    </div>
